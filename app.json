{
  "expo": {
    "name": "AudioSilo",
    "slug": "audiosilo",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "audiosilo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      },
      "bundleIdentifier": "app.audiosilo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.audiosilo",
      "permissions": ["android.permission.CAMERA"],
      "blockedPermissions": ["android.permission.ACTIVITY_RECOGNITION"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "locales": {
      "es": "./assets/locales/es.json",
      "fr": "./assets/locales/fr.json",
      "de": "./assets/locales/de.json",
      "pt": "./assets/locales/pt.json",
      "it": "./assets/locales/it.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1f2937",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AudioSilo to scan your server's pairing QR code.",
          "barcodeScannerEnabled": true,
          "recordAudioAndroid": false
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/web"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd711c89-9502-47ff-a881-eb5f043847a2"
      }
    }
  }
}
